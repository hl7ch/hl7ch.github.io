@prefix fhir: <http://hl7.org/fhir/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# - resource -------------------------------------------------------------------

<http://fhir.ch/ig/ch-term/Parameters/ExpansionParameters> a fhir:Parameters ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "ExpansionParameters"] ; # 
  fhir:parameter ( [
     fhir:name [ fhir:v "system-version" ] ;
     fhir:value [
       a fhir:Canonical ;
       fhir:v "http://snomed.info/sct|http://snomed.info/sct/2011000195101"^^xsd:anyURI ;
       fhir:l <http://snomed.info/sct?version=http://snomed.info/sct/2011000195101>
     ]
  ] [
     fhir:name [ fhir:v "includeDesignations" ] ;
     fhir:value [
       a fhir:Boolean ;
       fhir:v true
     ]
  ] ) . # 

