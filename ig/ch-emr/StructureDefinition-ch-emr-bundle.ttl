           fhir:v "http://fhir.ch/ig/ch-ips/StructureDefinition/ch-ips-medicationstatement"^^xsd:anyURI ;
           fhir:l <http://fhir.ch/ig/ch-ips/StructureDefinition/ch-ips-medicationstatement>
         ] )
       ] ) ;
